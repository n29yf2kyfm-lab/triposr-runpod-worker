{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expertcarcheck.com/schemas/vehicle-asset.schema.json",
  "title": "VehicleAsset",
  "type": "object",
  "required": [
    "schemaVersion", "assetId", "make", "model", "modelFamily",
    "provenance", "sourceTitle", "accuracyGrade", "qualityGrade",
    "technicalStatus", "visualStatus", "publicationStatus",
    "hasInterior", "interiorMode", "supportsOpenableParts",
    "defaultColourFamily", "desktopGlbUrl"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 2 },
    "assetId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{4,120}$" },
    "make": { "type": "string", "minLength": 2 },
    "model": { "type": "string", "minLength": 1 },
    "modelFamily": { "type": "string", "minLength": 1 },
    "modelAliases": { "type": "array", "items": { "type": "string" } },
    "generation": { "type": ["string", "null"] },
    "generationAliases": { "type": "array", "items": { "type": "string" } },
    "generationConfirmed": { "type": "boolean" },
    "yearStart": { "type": ["integer", "null"], "minimum": 1950, "maximum": 2030 },
    "yearEnd": { "type": ["integer", "null"], "minimum": 1950, "maximum": 2032 },
    "bodyStyle": { "type": ["string", "null"], "enum": [null, "hatchback", "saloon", "estate", "suv", "coupe", "convertible", "mpv", "pickup", "van", "roadster"] },
    "compatibleFuelTypes": { "type": "array", "items": { "type": "string" } },
    "compatibleTrimFamilies": { "type": "array", "items": { "type": "string" } },
    "exactDerivative": { "type": ["string", "null"] },
    "exactTrim": { "type": "boolean" },
    "provenance": { "enum": ["sourced", "generated-from-reference", "licensed", "hand-built"] },
    "sourceTitle": { "type": "string" },
    "sourceUrl": { "type": ["string", "null"] },
    "sourceCreator": { "type": ["string", "null"] },
    "sourceReferenceId": { "type": ["string", "null"] },
    "sourceRetrievedAt": { "type": ["string", "null"] },
    "sourceEvidenceUrl": { "type": ["string", "null"] },
    "licence": { "type": ["string", "null"] },
    "generatedFromReference": { "type": "boolean" },
    "referenceImageCount": { "type": "integer", "minimum": 0 },
    "accuracyGrade": { "enum": ["exact", "generation-correct", "representative", "approximate", "unavailable"] },
    "qualityGrade": { "enum": ["A", "B", "C", "rejected"] },
    "technicalStatus": { "enum": ["passed", "warning", "failed", "pending"] },
    "visualStatus": { "enum": ["passed", "warning", "failed", "pending"] },
    "publicationStatus": { "enum": ["approved", "quarantined", "needs-review", "retired"] },
    "quarantineReason": { "type": ["string", "null"] },
    "hasInterior": { "type": "boolean" },
    "interiorMode": { "enum": ["none", "panorama", "gaussian-splat", "mesh"] },
    "hasSeparateDoors": { "type": "boolean" },
    "hasSeparateBonnet": { "type": "boolean" },
    "hasSeparateBoot": { "type": "boolean" },
    "supportsOpenableParts": { "type": "boolean" },
    "paintMaterialNames": { "type": "array", "items": { "type": "string" } },
    "glassMaterialNames": { "type": "array", "items": { "type": "string" } },
    "defaultColourFamily": { "enum": ["black", "white", "grey", "silver", "blue", "red", "green", "yellow", "orange", "brown", "beige", "purple", "gold", "bronze", "multicolour", "unknown"] },
    "renderColourLabel": { "type": ["string", "null"] },
    "oemPaintVerified": { "type": "boolean" },
    "oemPaintCode": { "type": ["string", "null"] },
    "oemPaintName": { "type": ["string", "null"] },
    "colourVariants": { "type": "object", "additionalProperties": { "type": "string", "format": "uri" } },
    "desktopGlbUrl": { "type": "string", "format": "uri" },
    "mobileGlbUrl": { "type": ["string", "null"] },
    "fallbackGlbUrl": { "type": ["string", "null"] },
    "posterUrl": { "type": ["string", "null"] },
    "turntableUrl": { "type": ["string", "null"] },
    "interiorUrl": { "type": ["string", "null"] },
    "fileSizeBytes": { "type": ["integer", "null"], "minimum": 0 },
    "mobileFileSizeBytes": { "type": ["integer", "null"], "minimum": 0 },
    "triangleCount": { "type": ["integer", "null"], "minimum": 0 },
    "vertexCount": { "type": ["integer", "null"], "minimum": 0 },
    "textureMemoryBytes": { "type": ["integer", "null"], "minimum": 0 },
    "maxTextureResolution": { "type": ["integer", "null"], "minimum": 0 },
    "contentHash": { "type": ["string", "null"], "pattern": "^(sha256:[0-9a-f]{64})?$" },
    "pipelineVersion": { "type": ["string", "null"] },
    "publishedAt": { "type": ["string", "null"] },
    "replacedAssetId": { "type": ["string", "null"] },
    "needsHumanReview": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "array", "items": { "type": "string" } }
  }
}
